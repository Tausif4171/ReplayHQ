# Database
DATABASE_URL="postgresql://replayhq:replayhq_dev@localhost:5433/replayhq"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email delivery (optional)
# Used for password reset links and access request notifications.
# If unset, reset links are logged in development only.
RESEND_API_KEY=""
EMAIL_FROM="ReplayHQ <noreply@example.com>"
ACCESS_REQUEST_EMAIL=""

# MinIO (S3-compatible storage)
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_REGION="us-east-1"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="replayhq-recordings"
MINIO_USE_SSL=false

# Redis
REDIS_URL="redis://localhost:6379"
QUEUE_ADD_TIMEOUT_MS=2500

# Local AI: transcription. Place whisper.cpp model bin files at
# ~/whisper-models/ and point this variable at one of them.
#
# Trade-offs (size / quality / speed on Apple Silicon):
#   - ggml-base.en.bin    (141 MB, English-only, ~35x realtime)
#   - ggml-base.bin       (141 MB, multilingual, ~10x realtime, weak on Hindi)
#   - ggml-small.bin      (465 MB, multilingual, ~10x realtime, decent Hindi)
#   - ggml-large-v3.bin   (2.9 GB, multilingual, ~4x realtime, best quality) <-- recommended
#
# Download URL pattern: https://huggingface.co/ggerganov/whisper.cpp/resolve/main/<filename>
WHISPER_MODEL_PATH="/Users/<you>/whisper-models/ggml-large-v3.bin"

# Local AI: summarization
OLLAMA_BASE_URL="http://localhost:11434"
SUMMARIZE_MODEL="qwen2.5:7b"

# Zoom import integration (optional)
ZOOM_CLIENT_ID=""
ZOOM_CLIENT_SECRET=""
ZOOM_REDIRECT_URI="http://localhost:3000/api/zoom/callback"

# Worker logging (optional)
LOG_LEVEL="info"
TRANSCRIBE_RECOVERY_INTERVAL_MS=30000
TRANSCRIBE_RECOVERY_BATCH_SIZE=20
