# Database
DATABASE_URL="postgresql://replayhq:replayhq_dev@localhost:5432/replayhq"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# MinIO (S3-compatible storage)
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="replayhq-recordings"
MINIO_USE_SSL=false

# Redis
REDIS_URL="redis://localhost:6379"

# AI Services
OPENAI_API_KEY=""

# Slack Integration (Phase 2)
SLACK_BOT_TOKEN=""
SLACK_SIGNING_SECRET=""

# Local Whisper model for transcription. Place model bin files at
# ~/whisper-models/ and point this variable at one of them.
#
# Trade-offs (size / quality / speed on Apple Silicon):
#   - ggml-base.en.bin    (141 MB, English-only, ~35x realtime)
#   - ggml-base.bin       (141 MB, multilingual, ~10x realtime, weak on Hindi)
#   - ggml-small.bin      (465 MB, multilingual, ~10x realtime, decent Hindi)
#   - ggml-large-v3.bin   (2.9 GB, multilingual, ~4x realtime, best quality) <-- recommended
#
# Download URL pattern: https://huggingface.co/ggerganov/whisper.cpp/resolve/main/<filename>
WHISPER_MODEL_PATH="/Users/<you>/whisper-models/ggml-large-v3.bin"
