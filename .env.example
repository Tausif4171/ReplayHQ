# Database
DATABASE_URL="postgresql://replayhq:replayhq_dev@localhost:5432/replayhq"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# MinIO (S3-compatible storage)
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="replayhq-recordings"
MINIO_USE_SSL=false

# Redis
REDIS_URL="redis://localhost:6379"

# AI Services
OPENAI_API_KEY=""

# Slack Integration (Phase 2)
SLACK_BOT_TOKEN=""
SLACK_SIGNING_SECRET=""

# Local Whisper model for transcription. Defaults to
# ~/whisper-models/ggml-base.en.bin if unset. Use ggml-base.bin for
# multilingual support, ggml-large-v3.bin for higher quality.
WHISPER_MODEL_PATH=""
